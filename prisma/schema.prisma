generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  telegramId String  @unique
  username  String?
  mode      UserMode @default(orchestrator)
  apiKey    String?
  botToken  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum UserMode {
  bot
  orchestrator
}
