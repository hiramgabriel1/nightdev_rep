TELEGRAM_BOT_TOKEN=your_bot_token_here
DATABASE_URL="postgresql://user:password@localhost:5432/nightdev?schema=public"
OPENCLAW_BRIDGE_HOST=your_vps_ip
OPENCLAW_BRIDGE_PORT=your_bridge_port
OPENCLAW_BRIDGE_TOKEN=your_bridge_token

# Optional: HTTP server (defaults to 3000)
HTTP_PORT=3000

# Optional: Webhook mode (instead of polling). Must be HTTPS URL.
# TELEGRAM_WEBHOOK_URL=https://your-domain.com

# Optional: Admin API auth
# ADMIN_TOKEN=your_admin_secret
